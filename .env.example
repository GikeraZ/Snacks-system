# Required — Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="https://your-domain.vercel.app"
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"

# Database — PostgreSQL (Neon free tier)
# 1. Create free DB at https://neon.tech
# 2. Copy the connection string (it looks like: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require)
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# M-Pesa (optional — leave empty to use demo/simulation mode)
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_PASSKEY=""
MPESA_SHORTCODE="174379"
MPESA_CALLBACK_URL=""

# M-Pesa Callback Secret — shared secret to verify Safaricom callback authenticity
MPESA_CALLBACK_SECRET=""
